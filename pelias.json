{
  "esclient": {
    "hosts": [
      {
        "host": "elasticsearch",
        "port": 9200,
        "protocol": "http"
      }
    ]
  },
  "elasticsearch": {
    "settings": {
      "index": {
        "number_of_replicas": "0",
        "number_of_shards": "1"
      }
    }
  },
  "interpolation": {
    "client": {
      "adapter": "null"
    }
  },
  "api": {
    "host": "0.0.0.0",
    "port": 3100,
    "accessLog": "common",
    "legacyUrl": false
  },
  "acceptance-tests": {
    "endpoints": {
      "api": "http://localhost:3100/"
    }
  },
  "imports": {
    "adminLookup": {
      "enabled": true
    },
    "openstreetmap": {
      "import": []
    }
  }
}
