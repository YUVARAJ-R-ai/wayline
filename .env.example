# Wayline environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit the real `.env`.
# Used by docker-compose.yaml (dev) and docker-compose.prod.yaml (production).

# --- PostgreSQL / PostGIS ---
POSTGRES_DB=wayline
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_strong_password

# --- pgAdmin web UI (bound to localhost in production) ---
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change_me_strong_password

# --- Geocoding (OpenCage) ---
OPENCAGE_API_KEY=your_opencage_api_key

# --- API gateway JWT signing secret ---
# Generate one with:  openssl rand -hex 32
JWT_SECRET=change_me_random_64_hex_chars

# --- NextAuth (frontend) ---
# Required in production. Generate with:  openssl rand -base64 32
NEXTAUTH_SECRET=change_me_random_64_hex_chars
# Public URL users reach the app at.
# Docker (self-hosted): set to your Tailscale/domain URL, e.g. http://100.117.185.51
# Vercel: set this in the Vercel dashboard → Project Settings → Environment Variables
NEXTAUTH_URL=http://localhost

# --- Frontend API URL ---
# The public URL of the backend (tunnel / domain set up in #12).
# Docker (dev): leave empty — the frontend calls /api/* via Nginx on the same host.
# Vercel deployment: set in Vercel dashboard → Project Settings → Environment Variables:
#   NEXT_PUBLIC_API_URL = https://api.<yourdomain>   (the tunnel URL from #12)
NEXT_PUBLIC_API_URL=http://localhost:3000

# --- Backend URL (server-side, used by NextAuth in lib/auth.ts) ---
# Docker stack: uses Docker DNS "http://api-gateway:3000" (set in docker-compose files).
# Vercel deployment: set in Vercel dashboard → Project Settings → Environment Variables:
#   BACKEND_URL = https://api.<yourdomain>   (the tunnel URL from #12)
BACKEND_URL=http://api-gateway:3000

# --- Frontend Origin (CORS) ---
# The URL of the frontend application — used by api-gateway to allow CORS + bypass API key auth.
# Docker (dev):  http://localhost:8080
# Vercel:        https://wayline.vercel.app  (or your custom Vercel domain)
FRONTEND_ORIGIN=http://localhost:8080

# --- Production-only: where the pre-processed OSRM map data lives on the host ---
# This directory must contain southern-zone-latest.osrm and its companion files.
# Defaults to ./data/osrm-data if unset (used by docker-compose.prod.yaml).
OSRM_DATA_DIR=/data/wayline/osrm-data
